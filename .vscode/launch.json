{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug current Python file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug script: train.py (cosine)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/train.py",
      "args": ["--scheduler", "cosine", "--epochs", "6"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug Streamlit app",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": ["run", "src/objdetect/app/main.py"],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
