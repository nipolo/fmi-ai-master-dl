{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "setup",
      "type": "shell",
      "command": "uv sync",
      "detail": "Create .venv and install all runtime + dev dependencies",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "run:app",
      "type": "shell",
      "command": "uv run streamlit run objdetect/app/main.py",
      "detail": "Launch the object-detection web app",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "run:eda",
      "type": "shell",
      "command": "uv run python -m objdetect.eda.report",
      "detail": "Generate EDA figures + summary from COCO data",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "run:tests",
      "type": "shell",
      "command": "uv run pytest",
      "detail": "Run the BDD + unit test suite",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "gen:pptx",
      "type": "shell",
      "command": "marp reports/PRESENTATION.md --pptx --allow-local-files",
      "detail": "Render reports/PRESENTATION.md to PRESENTATION.pptx (Marp)",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
