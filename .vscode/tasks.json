{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "setup",
      "type": "shell",
      "command": "uv sync",
      "detail": "Create .venv and install all runtime + dev dependencies",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "run:app",
      "type": "shell",
      "command": "uv run streamlit run src/objdetect/app/main.py",
      "detail": "Launch the object-detection web app",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "run:eda",
      "type": "shell",
      "command": "uv run python scripts/run_eda.py",
      "detail": "Generate EDA figures + summary from COCO data",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "run:tests",
      "type": "shell",
      "command": "uv run pytest",
      "detail": "Run the BDD + unit test suite",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "nnga:regen-presentation",
      "type": "shell",
      "command": "sudo marp _NNGA/PRESENTATION.md --pptx --allow-local-files",
      "detail": "Render _NNGA/PRESENTATION.md to PRESENTATION.pptx (Marp)",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "nnga:run-ga",
      "type": "shell",
      "command": "uv run python _NNGA/src/evolve_hyperparameters.py --data DATA/traffic_cone/traffic_cone.yaml --epochs 10 --iterations 20 --device mps",
      "detail": "Evolve YOLO hyperparameters with the GA (traffic-cone, on-device MPS)",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "nnga:plot-evolution",
      "type": "shell",
      "command": "uv run python _NNGA/src/plot_evolution.py",
      "detail": "Regenerate the GA fitness-vs-generation figure from tune_results.ndjson",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "nnga:zip",
      "type": "shell",
      "command": "rm -rf .nnga_stage NNGA.zip && rsync -a --exclude runs --exclude Documentation --exclude .venv --exclude __pycache__ --exclude '.DS_Store' _NNGA/ .nnga_stage/NNGA/ && (cd .nnga_stage && zip -rq ../NNGA.zip NNGA) && rm -rf .nnga_stage",
      "detail": "Package _NNGA/ as NNGA.zip (top folder 'NNGA', no underscore; excludes runs, Documentation, .venv, caches)",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
